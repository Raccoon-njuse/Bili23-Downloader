#!/usr/bin/env sh
# Resolve a global symlink before locating this source checkout and its uv environment.
set -eu

SOURCE_PATH=$0
case "$SOURCE_PATH" in
    */*) ;;
    *) SOURCE_PATH=$(command -v "$SOURCE_PATH") ;;
esac

while [ -L "$SOURCE_PATH" ]; do
    SOURCE_DIR=$(CDPATH= cd -P "$(dirname "$SOURCE_PATH")" && pwd)
    LINK_TARGET=$(readlink "$SOURCE_PATH")
    case "$LINK_TARGET" in
        /*) SOURCE_PATH=$LINK_TARGET ;;
        *) SOURCE_PATH=$SOURCE_DIR/$LINK_TARGET ;;
    esac
done

PROJECT_DIR=$(CDPATH= cd -P "$(dirname "$SOURCE_PATH")" && pwd)
PYTHON_BIN="$PROJECT_DIR/.venv/bin/python"

if [ ! -x "$PYTHON_BIN" ]; then
    echo "未找到 $PYTHON_BIN；请先在 $PROJECT_DIR 中执行 uv sync" >&2
    exit 1
fi

PYTHONPATH="$PROJECT_DIR/src${PYTHONPATH:+:$PYTHONPATH}" exec "$PYTHON_BIN" "$PROJECT_DIR/src/bili23_cli.py" "$@"
